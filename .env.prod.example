# Copy to .env.prod and fill in secrets before: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# --- Required ---
BOT_TOKEN=
ADMIN_USER_IDS=
POSTGRES_PASSWORD=

# --- Bot instance ---
BOT_INSTANCE_ID=default

# --- PostgreSQL (used by compose to build DATABASE_URL) ---
POSTGRES_USER=bot
POSTGRES_DB=telegram_rag_bot

# --- Runtime ---
LOG_LEVEL=info
SYNC_SCHEDULER_ENABLED=true
RUN_DB_SEED=false

# --- Optional: external RAG service (mock when unset) ---
RAG_QUERY_URL=
RAG_QUERY_API_KEY=
RAG_INGEST_URL=
RAG_INGEST_API_KEY=
RAG_QUERY_TOP_K=5
RAG_FALLBACK_LOCAL=true
COMMUNITY_AUTO_INGEST_ON_APPROVE=true

# --- Image tag for registry deploys ---
BOT_IMAGE=telegram-rag-bot:latest