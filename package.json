{
  "name": "telegram-rag-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight Telegram group-assistant skeleton with RAG-ready architecture",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "start:prod": "node dist/src/index.js",
    "migrate:deploy": "prisma migrate deploy",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx scripts/seed.ts",
    "smoke-test": "tsx scripts/smoke-test.ts",
    "job:sync-chats": "tsx src/jobs/run-chat-sync.ts",
    "job:ingest-sources": "tsx src/jobs/run-source-ingest.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@grammyjs/conversations": "^2.0.3",
    "@prisma/client": "^6.9.0",
    "dotenv": "^16.5.0",
    "grammy": "^1.36.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}