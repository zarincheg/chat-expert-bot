# Telegram
BOT_TOKEN=your_bot_token_from_botfather

# Which bot instance config to load from DB (seed creates "default")
BOT_INSTANCE_ID=default

# Comma-separated Telegram user IDs allowed to use /admin
ADMIN_USER_IDS=123456789

# PostgreSQL (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://bot:bot@localhost:5432/telegram_rag_bot?schema=public

# Logging: debug | info | warn | error
LOG_LEVEL=info

# How many recent chat messages to include in RAG context
RAG_HISTORY_LIMIT=20

# In-process sync scheduler (dev). Production: use cron + npm run job:sync-chats
SYNC_SCHEDULER_ENABLED=false

# External RAG ingest API (optional — uses mock when unset)
RAG_INGEST_URL=
RAG_INGEST_API_KEY=

# External RAG query API (optional — uses mock when unset)
RAG_QUERY_URL=
RAG_QUERY_API_KEY=
RAG_QUERY_TOP_K=5
RAG_FALLBACK_LOCAL=true

# Source ingestion worker
SOURCE_INGEST_SCHEDULER_ENABLED=false
SOURCE_MAX_CHUNK_CHARS=2000

# Community answers: auto-ingest to RAG on moderator approval
COMMUNITY_AUTO_INGEST_ON_APPROVE=true

# Moderation — trust score API (mock when unset)
TRUST_SCORE_URL=
TRUST_SCORE_API_KEY=

# Admin web API + Auth.js (Telegram Login)
ADMIN_API_ENABLED=true
ADMIN_API_PORT=3001
AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
AUTH_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:5173