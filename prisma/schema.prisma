generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BotInstance {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  settings    Json     @default("{}")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  commands         BotCommand[]
  buttons          BotButton[]
  dataSources      DataSource[]
  chatMessages     ChatMessage[]
  knowledgeChunks  KnowledgeChunk[]
  chatSyncStates   ChatSyncState[]
  ingestionRuns    IngestionRun[]
  managedGroups    ManagedGroup[]
  sourceIngestRuns SourceIngestionRun[]
  communityAnswers CommunityAnswer[]
  questionLogs     QuestionLog[]
}

model ManagedGroup {
  id            String      @id @default(cuid())
  botInstanceId String
  botInstance   BotInstance @relation(fields: [botInstanceId], references: [id], onDelete: Cascade)
  chatId        BigInt
  title         String?
  topic         String?
  chatType      String
  settings      Json        @default("{}")
  isActive      Boolean     @default(true)
  memberStatus  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([botInstanceId, chatId])
  @@index([botInstanceId, isActive])
}

model BotCommand {
  id            String      @id @default(cuid())
  botInstanceId String
  botInstance   BotInstance @relation(fields: [botInstanceId], references: [id], onDelete: Cascade)
  name          String
  description   String
  response      String?
  isEnabled     Boolean     @default(true)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([botInstanceId, name])
  @@index([botInstanceId, isEnabled])
}

model BotButton {
  id            String      @id @default(cuid())
  botInstanceId String
  botInstance   BotInstance @relation(fields: [botInstanceId], references: [id], onDelete: Cascade)
  label         String
  actionType    String
  actionPayload Json?
  keyboardType  String      @default("inline")
  isEnabled     Boolean     @default(true)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([botInstanceId, isEnabled])
}

enum DataSourceType {
  URL
  FILE
  MANUAL
  CHAT_HISTORY
}

enum DataSourceStatus {
  PENDING
  ACTIVE
  ERROR
}

model DataSource {
  id             String           @id @default(cuid())
  botInstanceId  String
  botInstance    BotInstance      @relation(fields: [botInstanceId], references: [id], onDelete: Cascade)
  chatId         BigInt?
  name           String
  type           DataSourceType
  location       String
  status         DataSourceStatus @default(PENDING)
  metadata       Json?
  lastIngestedAt DateTime?
  lastError      String?
  chunkCount     Int              @default(0)
  ingestJobId    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  knowledgeChunks  KnowledgeChunk[]
  chatSyncStates   ChatSyncState[]
  sourceIngestRuns SourceIngestionRun[]

  @@index([botInstanceId, status])
  @@index([botInstanceId, chatId])
}

model SourceIngestionRun {
  id            String     @id @default(cuid())
  botInstanceId String
  botInstance   BotInstance @relation(fields: [botInstanceId], references: [id], onDelete: Cascade)
  dataSourceId  String
  dataSource    DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  startedAt     DateTime   @default(now())
  finishedAt    DateTime?
  status        String
  chunksSent    Int        @default(0)
  error         String?

  @@index([dataSourceId, startedAt])
}

model ChatMessage {
  id            String      @id @default(cuid())
  botInstanceId String
  botInstance   BotInstance @relation(fields: [botInstanceId], references: [id], onDelete: Cascade)
  chatId        BigInt
  userId        BigInt?
  username      String?
  role          String
  content       String
  messageId     BigInt?
  capturedFrom  String?
  contentHash   String?
  syncedAt      DateTime?
  createdAt     DateTime    @default(now())

  @@index([botInstanceId, chatId, createdAt])
  @@index([botInstanceId, chatId, syncedAt])
  @@unique([botInstanceId, chatId, messageId])
}

model ChatSyncState {
  id             String      @id @default(cuid())
  botInstanceId  String
  botInstance    BotInstance @relation(fields: [botInstanceId], references: [id], onDelete: Cascade)
  chatId         BigInt
  dataSourceId   String
  dataSource     DataSource  @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  lastSyncedAt   DateTime?
  lastMessageId  String?
  lastRunAt      DateTime?
  lastRunStatus  String?
  lastError      String?
  chunksExported Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([botInstanceId, chatId])
  @@index([botInstanceId])
}

model IngestionRun {
  id             String      @id @default(cuid())
  botInstanceId  String
  botInstance    BotInstance @relation(fields: [botInstanceId], references: [id], onDelete: Cascade)
  startedAt      DateTime    @default(now())
  finishedAt     DateTime?
  status         String
  chatsProcessed Int         @default(0)
  chunksSent     Int         @default(0)
  messagesSent   Int         @default(0)
  error          String?

  @@index([botInstanceId, startedAt])
}

model KnowledgeChunk {
  id            String      @id @default(cuid())
  botInstanceId String
  botInstance   BotInstance @relation(fields: [botInstanceId], references: [id], onDelete: Cascade)
  dataSourceId  String?
  dataSource    DataSource? @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)
  title         String?
  content       String
  keywords      String[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([botInstanceId])
}

enum CommunityAnswerStatus {
  CANDIDATE
  APPROVED
  REJECTED
  INGESTED
}

model CommunityAnswer {
  id              String                @id @default(cuid())
  botInstanceId   String
  botInstance     BotInstance           @relation(fields: [botInstanceId], references: [id], onDelete: Cascade)
  chatId          BigInt
  sourceMessageId BigInt
  sourceUserId    BigInt?
  sourceUsername  String?
  content         String
  title           String?
  status          CommunityAnswerStatus @default(CANDIDATE)
  endorsedById    BigInt?
  ingestedAt      DateTime?
  externalChunkId String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([botInstanceId, chatId, sourceMessageId])
  @@index([botInstanceId, chatId, status])
}

model QuestionLog {
  id                String   @id @default(cuid())
  botInstanceId     String
  botInstance       BotInstance @relation(fields: [botInstanceId], references: [id], onDelete: Cascade)
  chatId            BigInt
  userId            BigInt?
  question          String
  normalized        String
  answerSource      String
  communityAnswerId String?
  ragScore          Float?
  replyToMessageId  BigInt?
  createdAt         DateTime @default(now())

  @@index([botInstanceId, chatId, createdAt])
  @@index([botInstanceId, normalized])
}